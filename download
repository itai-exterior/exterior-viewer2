name: 3Dモデル自動公開(QR・一覧生成)

on:
  push:
    branches: [main]
    paths:
      - "models/**"
      - "viewer.html"
      - "scripts/**"
      - ".github/workflows/publish.yml"
  workflow_dispatch: {}   # 手動実行も可能(Actionsタブの Run workflow ボタン)

permissions:
  contents: write

concurrency:
  group: publish
  cancel-in-progress: true

jobs:
  generate:
    runs-on: ubuntu-latest
    steps:
      - name: リポジトリを取得
        uses: actions/checkout@v4

      - name: Python セットアップ
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: 依存ライブラリをインストール
        run: pip install "qrcode[pil]"

      # ── オプション: GLBを自動軽量化したい場合は以下のコメントを外す ──
      # (Draco圧縮・テクスチャ縮小。元ファイルを上書きするので注意)
      # - name: GLB軽量化 (gltf-transform)
      #   run: |
      #     npm install -g @gltf-transform/cli
      #     for f in models/*.glb; do
      #       [ -e "$f" ] || continue
      #       gltf-transform optimize "$f" "$f" --compress draco --texture-compress webp
      #     done

      - name: QRコード・一覧ページを生成
        env:
          GITHUB_REPOSITORY: ${{ github.repository }}
          # 独自ドメイン等を使う場合はリポジトリの Settings > Secrets and variables >
          # Actions > Variables に BASE_URL を登録すると、そちらが優先されます
          BASE_URL: ${{ vars.BASE_URL }}
        run: python scripts/generate_qr.py

      - name: 生成物をコミット
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add qr/ index.html models.json
          if git diff --cached --quiet; then
            echo "変更なし。コミットをスキップします。"
          else
            git commit -m "auto: QRコード・一覧ページを更新"
            git push
          fi
